msgctxt "Footer text for About Sync modal"
msgid ""
"%sLearn more%s about how chats are stored privately on DuckDuckGo's server."
msgstr ""
"%sMés informació%s sobre com s'emmagatzemen els xats de forma privada al "
"servidor del DuckDuckGo."

#. Text explaining that you can learn more about how recent chats work.
#. Placeholders are for page markup to add links to 'Learn more'. Example:
#. '<a>Learn more</a> about how chats are stored privately on your device.'
msgctxt "Information about adjusting recent chat storage settings"
msgid "%sLearn more%s about how chats are stored privately on your device."
msgstr ""
"%sMés informació%s sobre com s'emmagatzemen els xats de forma privada al "
"vostre dispositiu."

#. Tells the user to press and hold the DuckDuckGo app icon. Part of a list of
#. instructions on how to enable location service.
msgctxt "precise_user_location"
msgid "%sLong-press%s the DuckDuckGo app icon on the home screen"
msgstr ""
"%sMantingueu premuda%s la icona de l'aplicació DuckDuckGo a la pantalla d'inici"

#. A message displayed when there is an error loading content or no results on
#. requery
msgctxt "Error or no results message"
msgid "%sOops!%s%sSomething went wrong. Please %srefresh%s and try again."
msgstr "%sVaja!%s%sS'ha produït un error. %sRefresca%s i torneu-ho a provar."

#. Tagline in a popover encouraging the user to download the DuckDuckGo
#. browser
msgctxt "Browser Promo Popover"
msgid "%sProtection. Privacy.%s Peace of mind."
msgstr "%sProtecció. Privadesa.%s Tranquil·litat."

#. Prompts the user to reload the webpage.
msgctxt "precise_user_location"
msgid "%sReload%s DuckDuckGo, and try again"
msgstr "%sRecarregueu%s el DuckDuckGo, i torneu-ho a provar"

#. Prompts the user to reload the webpage.
msgctxt "precise_user_location"
msgid "%sReload%s DuckDuckGo, and try again."
msgstr "%sTorneu a carregar%s el DuckDuckGo i torneu-ho a provar."

#. A button that clears any filters that have been applied to search results.
msgctxt "noresults"
msgid "%sReset filters %s"
msgstr "%sRestableix els filtres %s"

#. Tells users where to click in their browser to change the default search
#. engine.
msgid "%sRight click%s in the search bar"
msgstr "Feu %sclic dret%s a la barra de cerca"

